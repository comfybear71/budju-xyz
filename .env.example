# ==========================================
# BUDJU Environment Variables
# ==========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ==========================================

# ── Database ──────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/
DB_NAME=flub

# ── Admin ─────────────────────────────────────────────────
# Comma-separated Solana wallet addresses with admin access
ADMIN_WALLETS=YourAdminWalletAddressHere

# ── Trading (Swyftx) ─────────────────────────────────────
SWYFTX_API_KEY=your_swyftx_api_key
# Emergency kill-switch: set to "false" to halt all auto-trades
TRADING_ENABLED=true
# Dry-run mode: set to "true" to simulate trades without executing
DRY_RUN=false
# Circuit breakers
MAX_SINGLE_TRADE_USDC=500
MAX_DAILY_TRADES=20
MAX_DAILY_LOSS_USDC=2000

# ── Solana RPC ────────────────────────────────────────────
HELIUS_API_KEY=your_helius_api_key

# ── Telegram Bot ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ── AI (Claude) ───────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Vercel ────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token
CRON_SECRET=your_cron_secret

# ── Frontend (VITE_ prefix required for client access) ────
VITE_ENVIRONMENT=development
VITE_PUBLIC_URL=http://localhost:5173
