# VPS Trading Bot Environment Variables
# Copy this to .env and fill in your values

# Solana RPC (Helius free tier)
HELIUS_API_KEY=your_helius_api_key_here

# Trading wallet private key (base58 encoded)
# IMPORTANT: Use a dedicated hot wallet, NOT your main wallet
TRADING_WALLET_KEY=your_base58_private_key_here

# MongoDB (same as your Vercel deployment)
MONGODB_URI=your_mongodb_uri_here
DB_NAME=flub

# Telegram notifications (optional, reuse existing bot)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Trading limits
MAX_SINGLE_TRADE_USD=50
MAX_DAILY_TRADES=50
MAX_DAILY_LOSS_USD=200
TRADING_ENABLED=true
DRY_RUN=true

# API server (for dashboard communication)
API_HOST=0.0.0.0
API_PORT=8420
API_SECRET=generate_a_random_secret_here
