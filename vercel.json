{
  "headers": [
    { "source": "/(.*)", "headers": [
      { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
      { "key": "Pragma", "value": "no-cache" },
      { "key": "Expires", "value": "0" }
    ]}
  ],
  "rewrites": [
    { "source": "/src/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/api/proxy", "destination": "/api/proxy.ts" },
    { "source": "/api/binance", "destination": "/api/klines.ts" },
    { "source": "/api/klines", "destination": "/api/klines.ts" },
    { "source": "/api/rpc", "destination": "/api/rpc.ts" },
    { "source": "/api/jupiter", "destination": "/api/jupiter.ts" },
    { "source": "/api/marketing", "destination": "/api/marketing.ts" },
    { "source": "/api/telegram", "destination": "/api/telegram.ts" },
    { "source": "/api/telegram-cron", "destination": "/api/telegram-cron.ts" },
    { "source": "/api/auto-trade-cron", "destination": "/api/auto-trade-cron.py" },
    { "source": "/api/perp-cron", "destination": "/api/perp-cron.py" },
    { "source": "/api/perp/:path*", "destination": "/api/index.py" },
    { "source": "/api/user/:path*", "destination": "/api/index.py" },
    { "source": "/api/user-deposit", "destination": "/api/index.py" },
    { "source": "/api/deposit", "destination": "/api/index.py" },
    { "source": "/api/trade", "destination": "/api/index.py" },
    { "source": "/api/trade/sync", "destination": "/api/index.py" },
    { "source": "/api/state", "destination": "/api/index.py" },
    { "source": "/api/users", "destination": "/api/index.py" },
    { "source": "/api/pool/:path*", "destination": "/api/index.py" },
    { "source": "/api/admin/:path*", "destination": "/api/index.py" },
    { "source": "/api/leaderboard", "destination": "/api/index.py" },
    { "source": "/api/transactions", "destination": "/api/index.py" },
    { "source": "/api/debug", "destination": "/api/index.py" },
    { "source": "/api/ml-training-data", "destination": "/api/index.py" },
    { "source": "/docs/:path*", "destination": "/docs/:path*" },
    { "source": "/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/telegram-cron",
      "schedule": "0 0,6,12,18 * * *"
    },
    {
      "path": "/api/auto-trade-cron",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/perp-cron",
      "schedule": "* * * * *"
    }
  ],
  "build": {
    "env": {
      "VITE_ASSET_PREFIX": "/assets"
    }
  }
}
